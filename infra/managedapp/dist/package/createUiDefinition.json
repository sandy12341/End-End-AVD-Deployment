{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy Azure Virtual Desktop into an existing virtual network and choose existing subnets from the target subscription.",
        "resourceGroup": {
          "allowExisting": true
        },
        "subscription": {
          "resourceProviders": [
            "Microsoft.Compute",
            "Microsoft.DesktopVirtualization",
            "Microsoft.KeyVault",
            "Microsoft.Network",
            "Microsoft.Storage"
          ]
        },
        "location": {
          "resourceTypes": [
            "Microsoft.Compute/virtualMachines",
            "Microsoft.DesktopVirtualization/hostPools",
            "Microsoft.Storage/storageAccounts"
          ]
        }
      }
    },
    "basics": [
      {
        "name": "deploymentPrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment Prefix",
        "defaultValue": "avd1",
        "toolTip": "Naming prefix used for resources other than the host pool.",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9]{1,6}$",
          "validationMessage": "Use 1-6 lowercase letters or digits."
        }
      },
      {
        "name": "environment",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "defaultValue": "dev",
        "constraints": {
          "required": true,
          "allowedValues": [
            {
              "label": "Development",
              "value": "dev"
            },
            {
              "label": "Test",
              "value": "test"
            },
            {
              "label": "Production",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "steps": [
      {
        "name": "instanceDetails",
        "label": "Instance details",
        "elements": [
          {
            "name": "hostPoolName",
            "type": "Microsoft.Common.TextBox",
            "label": "Host pool name",
            "defaultValue": "hp-avd-avd1-dev",
            "constraints": {
              "required": true,
              "regex": "^[A-Za-z0-9-]{3,64}$",
              "validationMessage": "Use 3-64 letters, numbers, or hyphens."
            }
          },
          {
            "name": "sessionHostCount",
            "type": "Microsoft.Common.Slider",
            "label": "Session Host Count",
            "min": 1,
            "max": 10,
            "defaultValue": 1,
            "showStepMarkers": true
          },
          {
            "name": "vmSize",
            "type": "Microsoft.Compute.SizeSelector",
            "label": "VM Size",
            "toolTip": "Select the Azure VM size for AVD session hosts. Recommended sizes are pre-filtered for AVD workloads.",
            "recommendedSizes": [
              "Standard_D2ads_v5",
              "Standard_D4ads_v5",
              "Standard_D8ads_v5",
              "Standard_D16ads_v5",
              "Standard_E2ads_v5",
              "Standard_E4ads_v5",
              "Standard_E8ads_v5"
            ],
            "constraints": {
              "allowedSizes": []
            },
            "options": {
              "hideDiskTypeFilter": false
            },
            "osPlatform": "Windows",
            "imageReference": {
              "publisher": "microsoftwindowsdesktop",
              "offer": "office-365",
              "sku": "win11-24h2-avd-m365"
            },
            "count": "[steps('instanceDetails').sessionHostCount]"
          },
          {
            "name": "imageSource",
            "type": "Microsoft.Common.DropDown",
            "label": "Image source",
            "defaultValue": "Marketplace",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Marketplace",
                  "value": "Marketplace"
                },
                {
                  "label": "Azure Compute Gallery",
                  "value": "AzureComputeGallery"
                }
              ]
            }
          },
          {
            "name": "avdCompatibleMarketplaceOs",
            "type": "Microsoft.Common.DropDown",
            "label": "Compatible OS",
            "toolTip": "Curated Azure Virtual Desktop-supported operating systems based on Microsoft Learn prerequisites.",
            "defaultValue": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}",
            "filter": true,
            "visible": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
              "allowedValues": [
                {
                  "label": "Windows 11 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win10-22h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2025",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2025-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2022",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"windowsserver2022\",\"sku\":\"2022-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2019",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2019-Datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2016",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2016-Datacenter\",\"version\":\"latest\"}"
                }
              ]
            }
          },
          {
            "name": "showAdvancedMarketplaceImageFields",
            "type": "Microsoft.Common.CheckBox",
            "label": "Show advanced Marketplace image fields",
            "defaultValue": false,
            "visible": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
            "toolTip": "Enable this only if you want to browse the full Marketplace catalog instead of using the curated AVD-supported OS list."
          },
          {
            "name": "marketplaceImagePublisher",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace publisher",
            "defaultValue": "microsoftwindowsdesktop",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageOffer",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace offer",
            "defaultValue": "windows-11",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageSku",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace SKU",
            "defaultValue": "win11-24h2-avd",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageVersion",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace version",
            "defaultValue": "latest",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "galleryPicker",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Azure Compute Gallery",
            "resourceType": "Microsoft.Compute/galleries",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "toolTip": "Select an existing Azure Compute Gallery. Use the subscription selector in the picker to browse across subscriptions. The default view shows galleries in the subscription selected on the Basics tab.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]"
            },
            "options": {}
          },
          {
            "name": "imageDefinitionsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), concat(steps('instanceDetails').galleryPicker.id, '/images?api-version=2022-08-03'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "galleryImageDefinitionName",
            "type": "Microsoft.Common.DropDown",
            "label": "Image definition",
            "placeholder": "Select an image definition...",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "toolTip": "Select the gallery image definition to use for session host VMs.",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "allowedValues": "[map(if(contains(steps('instanceDetails').imageDefinitionsApi, 'value'), steps('instanceDetails').imageDefinitionsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "galleryImageVersion",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery image version",
            "defaultValue": "latest",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "regex": "^latest$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
              "validationMessage": "Enter 'latest' or a version number like 1.0.0."
            }
          },
          {
            "name": "avdMode",
            "type": "Microsoft.Common.DropDown",
            "label": "AVD Mode",
            "defaultValue": "PooledDesktopAndRemoteApp",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Legacy pooled desktop",
                  "value": "LegacyPooledDesktop"
                },
                {
                  "label": "Personal Desktop",
                  "value": "PersonalDesktop"
                },
                {
                  "label": "Pooled RemoteApp",
                  "value": "PooledRemoteApp"
                },
                {
                  "label": "Pooled Desktop + RemoteApp",
                  "value": "PooledDesktopAndRemoteApp"
                }
              ]
            }
          },
          {
            "name": "hostPoolType",
            "type": "Microsoft.Common.DropDown",
            "label": "Host Pool Type",
            "defaultValue": "Pooled",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Pooled",
                  "value": "Pooled"
                },
                {
                  "label": "Personal",
                  "value": "Personal"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "networking",
        "label": "Networking",
        "elements": [
          {
            "name": "networkMode",
            "type": "Microsoft.Common.DropDown",
            "label": "Network deployment mode",
            "defaultValue": "Greenfield",
            "toolTip": "Greenfield creates a new dedicated spoke VNet. Brownfield connects AVD to a VNet and subnets you already manage.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Greenfield — create new spoke VNet and subnets",
                  "value": "Greenfield"
                },
                {
                  "label": "Brownfield — use existing VNet and subnets",
                  "value": "Brownfield"
                }
              ]
            }
          },
          {
            "name": "greenfieldVnetConfig",
            "type": "Microsoft.Network.VirtualNetworkCombo",
            "label": {
              "virtualNetwork": "New spoke virtual network",
              "subnets": "Subnets"
            },
            "toolTip": {
              "virtualNetwork": "Name and address space for the new spoke VNet that will be created for AVD session hosts.",
              "subnets": "Names and CIDR prefixes for the AVD subnets."
            },
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "defaultValue": {
              "name": "vnet-avd-spoke",
              "addressPrefixSize": "/16"
            },
            "constraints": {
              "minAddressPrefixSize": "/16"
            },
            "options": {
              "hideExisting": true
            },
            "subnets": {
              "sessionHostSubnet": {
                "label": "Session host subnet",
                "defaultValue": {
                  "name": "snet-avd-sessionhosts",
                  "addressPrefixSize": "/24"
                },
                "constraints": {
                  "minAddressPrefixSize": "/24",
                  "minCount": 1
                }
              },
              "privateEndpointSubnet": {
                "label": "Private endpoint subnet",
                "defaultValue": {
                  "name": "snet-avd-privateendpoints",
                  "addressPrefixSize": "/27"
                },
                "constraints": {
                  "minAddressPrefixSize": "/27",
                  "minCount": 1
                }
              }
            }
          },
          {
            "name": "hubVnet",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Hub virtual network (optional — for VNet peering)",
            "resourceType": "Microsoft.Network/virtualNetworks",
            "visible": "[equals(steps('networking').networkMode, 'Greenfield')]",
            "toolTip": "Select an existing hub VNet to peer the new spoke VNet with. Leave unselected to skip peering.",
            "options": {
              "filter": {
                "subscription": "onBasics"
              }
            }
          },
          {
            "name": "existingVnet",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Existing virtual network",
            "resourceType": "Microsoft.Network/virtualNetworks",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the VNet where AVD session hosts will be deployed.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]"
            },
            "options": {
              "filter": {
                "subscription": "onBasics",
                "location": "onBasics"
              }
            }
          },
          {
            "name": "subnetsApi",
            "type": "Microsoft.Solutions.ArmApiControl",
            "request": {
              "method": "GET",
              "path": "[if(and(equals(steps('networking').networkMode, 'Brownfield'), and(contains(steps('networking').existingVnet, 'id'), not(empty(steps('networking').existingVnet.id)))), concat(steps('networking').existingVnet.id, '/subnets?api-version=2023-09-01'), concat('/subscriptions/', subscription().subscriptionId, '/resourceGroups?api-version=2021-04-01'))]"
            }
          },
          {
            "name": "sessionHostSubnetName",
            "type": "Microsoft.Common.DropDown",
            "label": "Session host subnet",
            "placeholder": "Select a subnet...",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the subnet where AVD session host VMs will be deployed.",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]",
              "allowedValues": "[map(if(contains(steps('networking').subnetsApi, 'value'), steps('networking').subnetsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, ' (', coalesce(item.properties.addressPrefix, ''), ')\",\"value\":\"', item.name, '\"}')))]"
            }
          },
          {
            "name": "privateEndpointSubnetName",
            "type": "Microsoft.Common.DropDown",
            "label": "Private endpoint subnet",
            "placeholder": "Select a subnet...",
            "visible": "[equals(steps('networking').networkMode, 'Brownfield')]",
            "toolTip": "Select the subnet for AVD private endpoints (FSLogix storage, monitoring).",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'Brownfield')]",
              "allowedValues": "[map(if(contains(steps('networking').subnetsApi, 'value'), steps('networking').subnetsApi.value, take(split('x', ','), 0)), (item) => parse(concat('{\"label\":\"', item.name, ' (', coalesce(item.properties.addressPrefix, ''), ')\",\"value\":\"', item.name, '\"}')))]"
            }
          }
        ]
      },
      {
        "name": "storageMonitoring",
        "label": "Storage and monitoring",
        "elements": [
          {
            "name": "deployFSLogix",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy FSLogix storage",
            "defaultValue": true
          },
          {
            "name": "storageAccountName",
            "type": "Microsoft.Common.TextBox",
            "label": "Storage account name",
            "visible": "[steps('storageMonitoring').deployFSLogix]",
            "constraints": {
              "required": "[steps('storageMonitoring').deployFSLogix]",
              "regex": "^[a-z0-9]{3,24}$",
              "validationMessage": "Use 3-24 lowercase letters or digits."
            }
          },
          {
            "name": "deployMonitoring",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Log Analytics monitoring",
            "defaultValue": true
          }
        ]
      },
      {
        "name": "access",
        "label": "Access and applications",
        "elements": [
          {
            "name": "adminUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Local admin username",
            "defaultValue": "avdadmin",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "adminPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Local admin password",
              "confirmPassword": "Confirm local admin password"
            },
            "constraints": {
              "required": true,
              "regex": "^(?=.{12,})(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z0-9]).*$",
              "validationMessage": "Use at least 12 characters including upper, lower, number, and symbol."
            }
          },
          {
            "name": "desktopAssignments",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "Desktop app group access assignments",
            "label": "Desktop app group access assignments",
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'LegacyPooledDesktop'), equals(steps('instanceDetails').avdMode, 'PersonalDesktop'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 50
                }
              },
              "columns": [
                {
                  "id": "principalId",
                  "header": "Object ID",
                  "width": "2fr",
                  "element": {
                    "name": "principalId",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
                    "constraints": {
                      "required": true,
                      "regex": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                      "validationMessage": "Must be a valid GUID."
                    }
                  }
                },
                {
                  "id": "principalType",
                  "header": "Type",
                  "width": "1fr",
                  "element": {
                    "name": "principalType",
                    "type": "Microsoft.Common.DropDown",
                    "defaultValue": "User",
                    "constraints": {
                      "required": true,
                      "allowedValues": [
                        {
                          "label": "User",
                          "value": "User"
                        },
                        {
                          "label": "Group",
                          "value": "Group"
                        },
                        {
                          "label": "ServicePrincipal",
                          "value": "ServicePrincipal"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          {
            "name": "remoteAppAssignments",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "RemoteApp group access assignments",
            "label": "RemoteApp group access assignments",
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 50
                }
              },
              "columns": [
                {
                  "id": "principalId",
                  "header": "Object ID",
                  "width": "2fr",
                  "element": {
                    "name": "principalId",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
                    "constraints": {
                      "required": true,
                      "regex": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
                      "validationMessage": "Must be a valid GUID."
                    }
                  }
                },
                {
                  "id": "principalType",
                  "header": "Type",
                  "width": "1fr",
                  "element": {
                    "name": "principalType",
                    "type": "Microsoft.Common.DropDown",
                    "defaultValue": "User",
                    "constraints": {
                      "required": true,
                      "allowedValues": [
                        {
                          "label": "User",
                          "value": "User"
                        },
                        {
                          "label": "Group",
                          "value": "Group"
                        },
                        {
                          "label": "ServicePrincipal",
                          "value": "ServicePrincipal"
                        }
                      ]
                    }
                  }
                }
              ]
            }
          },
          {
            "name": "remoteApps",
            "type": "Microsoft.Common.EditableGrid",
            "ariaLabel": "RemoteApp definitions",
            "label": "RemoteApp definitions",
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Add one row per RemoteApp. Name and executable path are required.",
            "defaultValue": [],
            "constraints": {
              "width": "Full",
              "rows": {
                "count": {
                  "min": 0,
                  "max": 30
                }
              },
              "columns": [
                {
                  "id": "name",
                  "header": "App name",
                  "width": "1fr",
                  "element": {
                    "name": "name",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "Notepad",
                    "constraints": {
                      "required": true,
                      "regex": "^[^\\\\/:*?\"<>|]{1,64}$",
                      "validationMessage": "App name must be 1-64 characters and must not contain \\ / : * ? \" < > |"
                    }
                  }
                },
                {
                  "id": "filePath",
                  "header": "Executable path",
                  "width": "2fr",
                  "element": {
                    "name": "filePath",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "C:\\Windows\\System32\\notepad.exe",
                    "constraints": {
                      "required": true,
                      "regex": "^[A-Za-z]:\\\\.*\\.exe$",
                      "validationMessage": "Must be a full Windows path ending in .exe"
                    }
                  }
                },
                {
                  "id": "friendlyName",
                  "header": "Display name (optional)",
                  "width": "1fr",
                  "element": {
                    "name": "friendlyName",
                    "type": "Microsoft.Common.TextBox",
                    "placeholder": "Notepad",
                    "constraints": {
                      "required": false
                    }
                  }
                }
              ]
            }
          }
        ]
      },
      {
        "name": "authentication",
        "label": "Authentication",
        "elements": [
          {
            "name": "authenticationType",
            "type": "Microsoft.Common.DropDown",
            "label": "Authentication type",
            "defaultValue": "EntraID",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "EntraID",
                  "value": "EntraID"
                },
                {
                  "label": "HybridJoin",
                  "value": "HybridJoin"
                }
              ]
            }
          },
          {
            "name": "domainFqdn",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain FQDN",
            "defaultValue": "",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
              "regex": "^(?=.{3,255}$)(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$",
              "validationMessage": "Use a valid domain FQDN such as cloudaigeek.com."
            }
          },
          {
            "name": "domainJoinUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain join service account",
            "defaultValue": "",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
              "regex": "^([^\\\\\\s]+\\\\[^\\\\\\s]+|[^@\\s]+@[^@\\s]+|[^\\s]+)$",
              "validationMessage": "Use DOMAIN\\username or username@domain. Plain username is allowed and will be normalized automatically."
            }
          },
          {
            "name": "domainJoinPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Domain join service account password",
              "confirmPassword": "Confirm domain join service account password"
            },
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]"
            }
          },
          {
            "name": "domainJoinOuPath",
            "type": "Microsoft.Common.TextBox",
            "label": "Optional OU path",
            "defaultValue": "",
            "toolTip": "Example: OU=AVD,DC=contoso,DC=com",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": false,
              "regex": "^$|^(?=.{1,1024}$)(?:OU=[^,=]+,)*(?:DC=[^,=]+,)*DC=[^,=]+$",
              "validationMessage": "Use distinguished name format such as OU=AVD,DC=contoso,DC=com (or leave blank)."
            }
          },
          {
            "name": "entraUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Legacy shared Entra object IDs",
            "defaultValue": "",
            "multiLine": true,
            "toolTip": "Compatibility path. Optional shared User object IDs applied to all published app groups when EntraID authentication is selected.",
            "visible": "[equals(steps('authentication').authenticationType, 'EntraID')]",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          },
          {
            "name": "hybridUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Legacy shared hybrid user object IDs",
            "defaultValue": "",
            "multiLine": true,
            "toolTip": "Compatibility path. Optional shared User object IDs applied to all published app groups when HybridJoin is selected.",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          }
        ]
      }
    ],
    "outputs": {
      "applicationResourceName": "[steps('instanceDetails').hostPoolName]",
      "location": "[location()]",
      "deploymentPrefix": "[basics('deploymentPrefix')]",
      "networkMode": "[if(equals(steps('networking').networkMode, 'Greenfield'), 'CreateNewVnet', 'UseExistingVnet')]",
      "existingVnetName": "[if(equals(steps('networking').networkMode, 'Brownfield'), if(contains(steps('networking').existingVnet, 'name'), steps('networking').existingVnet.name, ''), '')]",
      "existingVnetResourceGroupName": "[if(equals(steps('networking').networkMode, 'Brownfield'), if(contains(steps('networking').existingVnet, 'id'), last(take(split(steps('networking').existingVnet.id, '/'), 5)), ''), '')]",
      "sessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').greenfieldVnetConfig, 'subnets'), steps('networking').greenfieldVnetConfig.subnets.sessionHostSubnet.name, 'snet-avd-sessionhosts'), if(empty(steps('networking').sessionHostSubnetName), 'snet-avd-sessionhosts', steps('networking').sessionHostSubnetName))]",
      "privateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').greenfieldVnetConfig, 'subnets'), steps('networking').greenfieldVnetConfig.subnets.privateEndpointSubnet.name, 'snet-avd-privateendpoints'), if(empty(steps('networking').privateEndpointSubnetName), 'snet-avd-privateendpoints', steps('networking').privateEndpointSubnetName))]",
      "newVnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').greenfieldVnetConfig, 'name'), steps('networking').greenfieldVnetConfig.name, 'vnet-avd-spoke'), '')]",
      "newVnetAddressPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(and(contains(steps('networking').greenfieldVnetConfig, 'addressPrefixes'), not(empty(steps('networking').greenfieldVnetConfig.addressPrefixes))), first(steps('networking').greenfieldVnetConfig.addressPrefixes), '10.20.0.0/16'), '')]",
      "newSessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').greenfieldVnetConfig, 'subnets'), steps('networking').greenfieldVnetConfig.subnets.sessionHostSubnet.name, 'snet-avd-sessionhosts'), '')]",
      "newSessionHostSubnetPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(and(contains(steps('networking').greenfieldVnetConfig, 'subnets'), not(empty(steps('networking').greenfieldVnetConfig.subnets.sessionHostSubnet.addressPrefix))), steps('networking').greenfieldVnetConfig.subnets.sessionHostSubnet.addressPrefix, '10.20.1.0/24'), '')]",
      "newPrivateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').greenfieldVnetConfig, 'subnets'), steps('networking').greenfieldVnetConfig.subnets.privateEndpointSubnet.name, 'snet-avd-privateendpoints'), '')]",
      "newPrivateEndpointSubnetPrefix": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(and(contains(steps('networking').greenfieldVnetConfig, 'subnets'), not(empty(steps('networking').greenfieldVnetConfig.subnets.privateEndpointSubnet.addressPrefix))), steps('networking').greenfieldVnetConfig.subnets.privateEndpointSubnet.addressPrefix, '10.20.2.0/24'), '')]",
      "hubVnetResourceId": "[if(equals(steps('networking').networkMode, 'Greenfield'), if(contains(steps('networking').hubVnet, 'id'), steps('networking').hubVnet.id, ''), '')]",
      "environment": "[basics('environment')]",
      "sessionHostCount": "[steps('instanceDetails').sessionHostCount]",
      "vmSize": "[steps('instanceDetails').vmSize]",
      "imageSource": "[steps('instanceDetails').imageSource]",
      "marketplaceImagePublisher": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).publisher, steps('instanceDetails').marketplaceImagePublisher)]",
      "marketplaceImageOffer": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).offer, steps('instanceDetails').marketplaceImageOffer)]",
      "marketplaceImageSku": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).sku, steps('instanceDetails').marketplaceImageSku)]",
      "marketplaceImageVersion": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(if(empty(steps('instanceDetails').avdCompatibleMarketplaceOs), '{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}', steps('instanceDetails').avdCompatibleMarketplaceOs)).version, steps('instanceDetails').marketplaceImageVersion)]",
      "galleryImageSubscriptionId": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), last(take(split(steps('instanceDetails').galleryPicker.id, '/'), 3)), subscription().subscriptionId)]",
      "galleryImageResourceGroupName": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), and(contains(steps('instanceDetails').galleryPicker, 'id'), not(empty(steps('instanceDetails').galleryPicker.id)))), last(take(split(steps('instanceDetails').galleryPicker.id, '/'), 5)), '')]",
      "galleryName": "[if(and(equals(steps('instanceDetails').imageSource, 'AzureComputeGallery'), contains(steps('instanceDetails').galleryPicker, 'name')), steps('instanceDetails').galleryPicker.name, '')]",
      "galleryImageDefinitionName": "[steps('instanceDetails').galleryImageDefinitionName]",
      "galleryImageVersion": "[steps('instanceDetails').galleryImageVersion]",
      "avdMode": "[if(equals(steps('instanceDetails').avdMode, 'LegacyPooledDesktop'), '', steps('instanceDetails').avdMode)]",
      "hostPoolType": "[steps('instanceDetails').hostPoolType]",
      "hostPoolName": "[steps('instanceDetails').hostPoolName]",
      "adminUsername": "[steps('access').adminUsername]",
      "adminPassword": "[steps('access').adminPassword]",
      "authenticationType": "[steps('authentication').authenticationType]",
      "domainFqdn": "[steps('authentication').domainFqdn]",
      "domainJoinUsername": "[steps('authentication').domainJoinUsername]",
      "domainJoinPassword": "[steps('authentication').domainJoinPassword]",
      "domainJoinOuPath": "[steps('authentication').domainJoinOuPath]",
      "deployFSLogix": "[steps('storageMonitoring').deployFSLogix]",
      "storageAccountName": "[steps('storageMonitoring').storageAccountName]",
      "deployMonitoring": "[steps('storageMonitoring').deployMonitoring]",
      "avdUserObjectIds": "[if(equals(steps('authentication').authenticationType, 'EntraID'), steps('authentication').entraUserObjectIds, steps('authentication').hybridUserObjectIds)]",
      "desktopAccessAssignments": "[steps('access').desktopAssignments]",
      "remoteAppAccessAssignments": "[steps('access').remoteAppAssignments]",
      "remoteApps": "[steps('access').remoteApps]"
    }
  }
}
