{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": true,
      "basics": {
        "description": "Deploy Azure Virtual Desktop into an existing virtual network and choose existing subnets from the target subscription.",
        "resourceGroup": {
          "allowExisting": true
        },
        "subscription": {
          "resourceProviders": [
            "Microsoft.Compute",
            "Microsoft.DesktopVirtualization",
            "Microsoft.KeyVault",
            "Microsoft.Network",
            "Microsoft.Storage"
          ]
        },
        "location": {
          "resourceTypes": [
            "Microsoft.Compute/virtualMachines",
            "Microsoft.DesktopVirtualization/hostPools",
            "Microsoft.Storage/storageAccounts"
          ]
        }
      }
    },
    "basics": [
      {
        "name": "deploymentPrefix",
        "type": "Microsoft.Common.TextBox",
        "label": "Deployment Prefix",
        "defaultValue": "avd1",
        "toolTip": "Naming prefix used for resources other than the host pool.",
        "constraints": {
          "required": true,
          "regex": "^[a-z0-9]{1,6}$",
          "validationMessage": "Use 1-6 lowercase letters or digits."
        }
      },
      {
        "name": "environment",
        "type": "Microsoft.Common.DropDown",
        "label": "Environment",
        "defaultValue": "dev",
        "constraints": {
          "required": true,
          "allowedValues": [
            {
              "label": "Development",
              "value": "dev"
            },
            {
              "label": "Test",
              "value": "test"
            },
            {
              "label": "Production",
              "value": "prod"
            }
          ]
        }
      }
    ],
    "steps": [
      {
        "name": "instanceDetails",
        "label": "Instance details",
        "elements": [
          {
            "name": "hostPoolName",
            "type": "Microsoft.Common.TextBox",
            "label": "Host pool name",
            "defaultValue": "hp-avd-avd1-dev",
            "constraints": {
              "required": true,
              "regex": "^[A-Za-z0-9-]{3,64}$",
              "validationMessage": "Use 3-64 letters, numbers, or hyphens."
            }
          },
          {
            "name": "sessionHostCount",
            "type": "Microsoft.Common.Slider",
            "label": "Session Host Count",
            "min": 1,
            "max": 10,
            "defaultValue": 1,
            "showStepMarkers": true
          },
          {
            "name": "vmSize",
            "type": "Microsoft.Common.DropDown",
            "label": "VM Size",
            "defaultValue": "Standard_D2ads_v5",
            "filter": true,
            "constraints": {
              "required": true,
              "allowedValues": [
                { "label": "Standard_D2ads_v5 (2 vCPU, 8 GiB)", "value": "Standard_D2ads_v5" },
                { "label": "Standard_D4ads_v5 (4 vCPU, 16 GiB)", "value": "Standard_D4ads_v5" },
                { "label": "Standard_D8ads_v5 (8 vCPU, 32 GiB)", "value": "Standard_D8ads_v5" },
                { "label": "Standard_D16ads_v5 (16 vCPU, 64 GiB)", "value": "Standard_D16ads_v5" },
                { "label": "Standard_D32ads_v5 (32 vCPU, 128 GiB)", "value": "Standard_D32ads_v5" },
                { "label": "Standard_E2ads_v5 (2 vCPU, 16 GiB)", "value": "Standard_E2ads_v5" },
                { "label": "Standard_E4ads_v5 (4 vCPU, 32 GiB)", "value": "Standard_E4ads_v5" },
                { "label": "Standard_E8ads_v5 (8 vCPU, 64 GiB)", "value": "Standard_E8ads_v5" },
                { "label": "Standard_NV6ads_A10_v5 (6 vCPU, 55 GiB — GPU)", "value": "Standard_NV6ads_A10_v5" },
                { "label": "Standard_NV12ads_A10_v5 (12 vCPU, 110 GiB — GPU)", "value": "Standard_NV12ads_A10_v5" }
              ]
            }
          },
          {
            "name": "imageSource",
            "type": "Microsoft.Common.DropDown",
            "label": "Image source",
            "defaultValue": "Marketplace",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Marketplace",
                  "value": "Marketplace"
                },
                {
                  "label": "Azure Compute Gallery",
                  "value": "AzureComputeGallery"
                }
              ]
            }
          },
          {
            "name": "avdCompatibleMarketplaceOs",
            "type": "Microsoft.Common.DropDown",
            "label": "Compatible OS",
            "toolTip": "Curated Azure Virtual Desktop-supported operating systems based on Microsoft Learn prerequisites.",
            "defaultValue": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}",
            "filter": true,
            "visible": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
              "allowedValues": [
                {
                  "label": "Windows 11 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win11-24h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 11 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"windows-11\",\"sku\":\"win11-24h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session + Microsoft 365 Apps",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"office-365\",\"sku\":\"win10-22h2-avd-m365\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise multi-session",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-avd\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows 10 Enterprise",
                  "value": "{\"publisher\":\"microsoftwindowsdesktop\",\"offer\":\"Windows-10\",\"sku\":\"win10-22h2-ent\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2025",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2025-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2022",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"windowsserver2022\",\"sku\":\"2022-datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2019",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2019-Datacenter\",\"version\":\"latest\"}"
                },
                {
                  "label": "Windows Server 2016",
                  "value": "{\"publisher\":\"MicrosoftWindowsServer\",\"offer\":\"WindowsServer\",\"sku\":\"2016-Datacenter\",\"version\":\"latest\"}"
                }
              ]
            }
          },
          {
            "name": "showAdvancedMarketplaceImageFields",
            "type": "Microsoft.Common.CheckBox",
            "label": "Show advanced Marketplace image fields",
            "defaultValue": false,
            "visible": "[equals(steps('instanceDetails').imageSource, 'Marketplace')]",
            "toolTip": "Enable this only if you want to browse the full Marketplace catalog instead of using the curated AVD-supported OS list."
          },
          {
            "name": "marketplaceImagePublisher",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace publisher",
            "defaultValue": "microsoftwindowsdesktop",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageOffer",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace offer",
            "defaultValue": "windows-11",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageSku",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace SKU",
            "defaultValue": "win11-24h2-avd",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "marketplaceImageVersion",
            "type": "Microsoft.Common.TextBox",
            "label": "Marketplace version",
            "defaultValue": "latest",
            "visible": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]",
            "constraints": {
              "required": "[and(equals(steps('instanceDetails').imageSource, 'Marketplace'), steps('instanceDetails').showAdvancedMarketplaceImageFields)]"
            }
          },
          {
            "name": "galleryImageSubscriptionId",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery subscription ID",
            "defaultValue": "",
            "toolTip": "Leave blank to use the deployment subscription. Enter a GUID to target a different subscription.",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": false,
              "regex": "^$|^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
              "validationMessage": "Leave blank or enter a valid subscription GUID."
            }
          },
          {
            "name": "galleryImageResourceGroupName",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery resource group",
            "defaultValue": "",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "regex": "^[A-Za-z0-9._()-]{1,90}$",
              "validationMessage": "Enter the resource group name that contains the Compute Gallery."
            }
          },
          {
            "name": "galleryName",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery name",
            "defaultValue": "",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "regex": "^[A-Za-z0-9._]{1,80}$",
              "validationMessage": "Enter the Azure Compute Gallery name."
            }
          },
          {
            "name": "galleryImageDefinitionName",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery image definition",
            "defaultValue": "",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "regex": "^[A-Za-z0-9._-]{1,80}$",
              "validationMessage": "Enter the gallery image definition name."
            }
          },
          {
            "name": "galleryImageVersion",
            "type": "Microsoft.Common.TextBox",
            "label": "Gallery image version",
            "defaultValue": "latest",
            "visible": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
            "constraints": {
              "required": "[equals(steps('instanceDetails').imageSource, 'AzureComputeGallery')]",
              "regex": "^latest$|^[0-9]+\\.[0-9]+\\.[0-9]+$",
              "validationMessage": "Enter 'latest' or a version number like 1.0.0."
            }
          },
          {
            "name": "avdMode",
            "type": "Microsoft.Common.DropDown",
            "label": "AVD Mode",
            "defaultValue": "PooledDesktopAndRemoteApp",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Legacy pooled desktop",
                  "value": "LegacyPooledDesktop"
                },
                {
                  "label": "Personal Desktop",
                  "value": "PersonalDesktop"
                },
                {
                  "label": "Pooled RemoteApp",
                  "value": "PooledRemoteApp"
                },
                {
                  "label": "Pooled Desktop + RemoteApp",
                  "value": "PooledDesktopAndRemoteApp"
                }
              ]
            }
          },
          {
            "name": "hostPoolType",
            "type": "Microsoft.Common.DropDown",
            "label": "Host Pool Type",
            "defaultValue": "Pooled",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Pooled",
                  "value": "Pooled"
                },
                {
                  "label": "Personal",
                  "value": "Personal"
                }
              ]
            }
          }
        ]
      },
      {
        "name": "networking",
        "label": "Networking",
        "elements": [
          {
            "name": "networkMode",
            "type": "Microsoft.Common.DropDown",
            "label": "Network mode",
            "defaultValue": "UseExistingVnet",
            "toolTip": "Use brownfield mode to deploy into an existing VNet, or greenfield mode to create a new spoke VNet and peer it with an existing hub VNet.",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "Use existing VNet",
                  "value": "UseExistingVnet"
                },
                {
                  "label": "Create new VNet",
                  "value": "CreateNewVnet"
                }
              ]
            }
          },
          {
            "name": "existingVnetResourceGroupName",
            "type": "Microsoft.Common.TextBox",
            "label": "Existing VNet resource group",
            "toolTip": "Resource group that contains the existing virtual network.",
            "visible": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
              "regex": "^[A-Za-z0-9._()-]{1,90}$",
              "validationMessage": "Enter the resource group name."
            }
          },
          {
            "name": "existingVnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Existing virtual network name",
            "toolTip": "Name of the existing VNet where AVD session hosts will be deployed.",
            "visible": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,62}$",
              "validationMessage": "Enter the virtual network name."
            }
          },
          {
            "name": "sessionHostSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Session host subnet",
            "toolTip": "Name of the existing subnet for AVD session host NICs.",
            "visible": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,79}$",
              "validationMessage": "Enter the subnet name."
            }
          },
          {
            "name": "privateEndpointSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Private endpoint subnet",
            "toolTip": "Name of the existing subnet reserved for private endpoints.",
            "visible": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'UseExistingVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,79}$",
              "validationMessage": "Enter the subnet name."
            }
          },
          {
            "name": "hubVnet",
            "type": "Microsoft.Common.TextBox",
            "label": "Hub virtual network resource ID",
            "toolTip": "Full resource ID of the existing hub VNet to peer with. Format: /subscriptions/{guid}/resourceGroups/{rg}/providers/Microsoft.Network/virtualNetworks/{name}",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^/subscriptions/[^/]+/resourceGroups/[^/]+/providers/Microsoft\\.Network/virtualNetworks/[^/]+$",
              "validationMessage": "Enter the full VNet resource ID."
            }
          },
          {
            "name": "newVnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "New virtual network name",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,62}$",
              "validationMessage": "Use 1-63 letters, digits, hyphens, underscores, or periods."
            }
          },
          {
            "name": "newVnetAddressPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "New virtual network CIDR",
            "defaultValue": "10.20.0.0/16",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/(?:[0-9]|[1-2][0-9]|3[0-2])$",
              "validationMessage": "Enter a CIDR such as 10.20.0.0/16."
            }
          },
          {
            "name": "newSessionHostSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Session host subnet name",
            "defaultValue": "snet-avd-sessionhosts",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,79}$",
              "validationMessage": "Use 1-80 letters, digits, hyphens, underscores, or periods."
            }
          },
          {
            "name": "newSessionHostSubnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Session host subnet CIDR",
            "defaultValue": "10.20.1.0/24",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/(?:[0-9]|[1-2][0-9]|3[0-2])$",
              "validationMessage": "Enter a CIDR such as 10.20.1.0/24."
            }
          },
          {
            "name": "newPrivateEndpointSubnetName",
            "type": "Microsoft.Common.TextBox",
            "label": "Private endpoint subnet name",
            "defaultValue": "snet-avd-privateendpoints",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^[A-Za-z0-9][A-Za-z0-9-_.]{0,79}$",
              "validationMessage": "Use 1-80 letters, digits, hyphens, underscores, or periods."
            }
          },
          {
            "name": "newPrivateEndpointSubnetPrefix",
            "type": "Microsoft.Common.TextBox",
            "label": "Private endpoint subnet CIDR",
            "defaultValue": "10.20.2.0/24",
            "visible": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
            "constraints": {
              "required": "[equals(steps('networking').networkMode, 'CreateNewVnet')]",
              "regex": "^(?:[0-9]{1,3}\\.){3}[0-9]{1,3}/(?:[0-9]|[1-2][0-9]|3[0-2])$",
              "validationMessage": "Enter a CIDR such as 10.20.2.0/24."
            }
          }
        ]
      },
      {
        "name": "storageMonitoring",
        "label": "Storage and monitoring",
        "elements": [
          {
            "name": "deployFSLogix",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy FSLogix storage",
            "defaultValue": true
          },
          {
            "name": "storageAccountName",
            "type": "Microsoft.Common.TextBox",
            "label": "Storage account name",
            "visible": "[steps('storageMonitoring').deployFSLogix]",
            "constraints": {
              "required": "[steps('storageMonitoring').deployFSLogix]",
              "regex": "^[a-z0-9]{3,24}$",
              "validationMessage": "Use 3-24 lowercase letters or digits."
            }
          },
          {
            "name": "deployMonitoring",
            "type": "Microsoft.Common.CheckBox",
            "label": "Deploy Log Analytics monitoring",
            "defaultValue": true
          }
        ]
      },
      {
        "name": "access",
        "label": "Access and applications",
        "elements": [
          {
            "name": "adminUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Local admin username",
            "defaultValue": "avdadmin",
            "constraints": {
              "required": true
            }
          },
          {
            "name": "adminPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Local admin password",
              "confirmPassword": "Confirm local admin password"
            },
            "constraints": {
              "required": true,
              "regex": "^(?=.{12,})(?=.*[A-Z])(?=.*[a-z])(?=.*\\d)(?=.*[^A-Za-z0-9]).*$",
              "validationMessage": "Use at least 12 characters including upper, lower, number, and symbol."
            }
          },
          {
            "name": "remoteAppsJson",
            "type": "Microsoft.Common.TextBox",
            "label": "RemoteApp definitions (JSON array)",
            "defaultValue": "[]",
            "multiLine": true,
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Each item must include name and filePath and can optionally include friendlyName, description, commandLineSetting, and commandLineArguments.",
            "constraints": {
              "required": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]"
            }
          },
          {
            "name": "desktopUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Desktop user object IDs",
            "defaultValue": "",
            "multiLine": true,
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'LegacyPooledDesktop'), equals(steps('instanceDetails').avdMode, 'PersonalDesktop'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Optional. Comma-separated or newline-separated Microsoft Entra user object IDs.",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          },
          {
            "name": "desktopGroupObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Desktop group object IDs",
            "defaultValue": "",
            "multiLine": true,
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'LegacyPooledDesktop'), equals(steps('instanceDetails').avdMode, 'PersonalDesktop'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Optional. Comma-separated or newline-separated Microsoft Entra group object IDs.",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          },
          {
            "name": "remoteAppUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "RemoteApp user object IDs",
            "defaultValue": "",
            "multiLine": true,
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Optional. Comma-separated or newline-separated Microsoft Entra user object IDs.",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          },
          {
            "name": "remoteAppGroupObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "RemoteApp group object IDs",
            "defaultValue": "",
            "multiLine": true,
            "visible": "[or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp'))]",
            "toolTip": "Optional. Comma-separated or newline-separated Microsoft Entra group object IDs.",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          }
        ]
      },
      {
        "name": "authentication",
        "label": "Authentication",
        "elements": [
          {
            "name": "authenticationType",
            "type": "Microsoft.Common.DropDown",
            "label": "Authentication type",
            "defaultValue": "EntraID",
            "constraints": {
              "required": true,
              "allowedValues": [
                {
                  "label": "EntraID",
                  "value": "EntraID"
                },
                {
                  "label": "HybridJoin",
                  "value": "HybridJoin"
                }
              ]
            }
          },
          {
            "name": "domainFqdn",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain FQDN",
            "defaultValue": "",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
              "regex": "^(?=.{3,255}$)(?!-)(?:[A-Za-z0-9-]{1,63}\\.)+[A-Za-z]{2,63}$",
              "validationMessage": "Use a valid domain FQDN such as cloudaigeek.com."
            }
          },
          {
            "name": "domainJoinUsername",
            "type": "Microsoft.Common.TextBox",
            "label": "Domain join service account",
            "defaultValue": "",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
              "regex": "^([^\\\\\\s]+\\\\[^\\\\\\s]+|[^@\\s]+@[^@\\s]+|[^\\s]+)$",
              "validationMessage": "Use DOMAIN\\username or username@domain. Plain username is allowed and will be normalized automatically."
            }
          },
          {
            "name": "domainJoinPassword",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Domain join service account password",
              "confirmPassword": "Confirm domain join service account password"
            },
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": "[equals(steps('authentication').authenticationType, 'HybridJoin')]"
            }
          },
          {
            "name": "domainJoinOuPath",
            "type": "Microsoft.Common.TextBox",
            "label": "Optional OU path",
            "defaultValue": "",
            "toolTip": "Example: OU=AVD,DC=contoso,DC=com",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": false,
              "regex": "^$|^(?=.{1,1024}$)(?:OU=[^,=]+,)*(?:DC=[^,=]+,)*DC=[^,=]+$",
              "validationMessage": "Use distinguished name format such as OU=AVD,DC=contoso,DC=com (or leave blank)."
            }
          },
          {
            "name": "entraUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Legacy shared Entra object IDs",
            "defaultValue": "",
            "multiLine": true,
            "toolTip": "Compatibility path. Optional shared User object IDs applied to all published app groups when EntraID authentication is selected.",
            "visible": "[equals(steps('authentication').authenticationType, 'EntraID')]",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          },
          {
            "name": "hybridUserObjectIds",
            "type": "Microsoft.Common.TextBox",
            "label": "Legacy shared hybrid user object IDs",
            "defaultValue": "",
            "multiLine": true,
            "toolTip": "Compatibility path. Optional shared User object IDs applied to all published app groups when HybridJoin is selected.",
            "visible": "[equals(steps('authentication').authenticationType, 'HybridJoin')]",
            "constraints": {
              "required": false,
              "regex": "^\\s*$|^\\s*[0-9a-fA-F-]{36}(\\s*[,\\n]\\s*[0-9a-fA-F-]{36})*\\s*$",
              "validationMessage": "Use one or more GUID object IDs separated by commas or new lines."
            }
          }
        ]
      }
    ],
    "outputs": {
      "applicationResourceName": "[steps('instanceDetails').hostPoolName]",
      "location": "[location()]",
      "deploymentPrefix": "[basics('deploymentPrefix')]",
      "environment": "[basics('environment')]",
      "sessionHostCount": "[steps('instanceDetails').sessionHostCount]",
      "vmSize": "[steps('instanceDetails').vmSize]",
      "imageSource": "[steps('instanceDetails').imageSource]",
      "marketplaceImagePublisher": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(steps('instanceDetails').avdCompatibleMarketplaceOs).publisher, steps('instanceDetails').marketplaceImagePublisher)]",
      "marketplaceImageOffer": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(steps('instanceDetails').avdCompatibleMarketplaceOs).offer, steps('instanceDetails').marketplaceImageOffer)]",
      "marketplaceImageSku": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(steps('instanceDetails').avdCompatibleMarketplaceOs).sku, steps('instanceDetails').marketplaceImageSku)]",
      "marketplaceImageVersion": "[if(and(equals(steps('instanceDetails').imageSource, 'Marketplace'), not(steps('instanceDetails').showAdvancedMarketplaceImageFields)), parse(steps('instanceDetails').avdCompatibleMarketplaceOs).version, steps('instanceDetails').marketplaceImageVersion)]",
      "galleryImageSubscriptionId": "[if(empty(steps('instanceDetails').galleryImageSubscriptionId), subscription().subscriptionId, steps('instanceDetails').galleryImageSubscriptionId)]",
      "galleryImageResourceGroupName": "[steps('instanceDetails').galleryImageResourceGroupName]",
      "galleryName": "[steps('instanceDetails').galleryName]",
      "galleryImageDefinitionName": "[steps('instanceDetails').galleryImageDefinitionName]",
      "galleryImageVersion": "[steps('instanceDetails').galleryImageVersion]",
      "avdMode": "[if(equals(steps('instanceDetails').avdMode, 'LegacyPooledDesktop'), '', steps('instanceDetails').avdMode)]",
      "hostPoolType": "[steps('instanceDetails').hostPoolType]",
      "hostPoolName": "[steps('instanceDetails').hostPoolName]",
      "networkMode": "[steps('networking').networkMode]",
      "existingVnetName": "[if(equals(steps('networking').networkMode, 'UseExistingVnet'), steps('networking').existingVnetName, '')]",
      "existingVnetResourceGroupName": "[if(equals(steps('networking').networkMode, 'UseExistingVnet'), steps('networking').existingVnetResourceGroupName, '')]",
      "sessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'UseExistingVnet'), steps('networking').sessionHostSubnetName, '')]",
      "privateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'UseExistingVnet'), steps('networking').privateEndpointSubnetName, '')]",
      "newVnetName": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newVnetName, '')]",
      "newVnetAddressPrefix": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newVnetAddressPrefix, '10.20.0.0/16')]",
      "newSessionHostSubnetName": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newSessionHostSubnetName, 'snet-avd-sessionhosts')]",
      "newSessionHostSubnetPrefix": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newSessionHostSubnetPrefix, '10.20.1.0/24')]",
      "newPrivateEndpointSubnetName": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newPrivateEndpointSubnetName, 'snet-avd-privateendpoints')]",
      "newPrivateEndpointSubnetPrefix": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').newPrivateEndpointSubnetPrefix, '10.20.2.0/24')]",
      "hubVnetResourceId": "[if(equals(steps('networking').networkMode, 'CreateNewVnet'), steps('networking').hubVnet, '')]",
      "adminUsername": "[steps('access').adminUsername]",
      "adminPassword": "[steps('access').adminPassword]",
      "authenticationType": "[steps('authentication').authenticationType]",
      "domainFqdn": "[steps('authentication').domainFqdn]",
      "domainJoinUsername": "[steps('authentication').domainJoinUsername]",
      "domainJoinPassword": "[steps('authentication').domainJoinPassword]",
      "domainJoinOuPath": "[steps('authentication').domainJoinOuPath]",
      "deployFSLogix": "[steps('storageMonitoring').deployFSLogix]",
      "storageAccountName": "[steps('storageMonitoring').storageAccountName]",
      "deployMonitoring": "[steps('storageMonitoring').deployMonitoring]",
      "avdUserObjectIds": "[if(equals(steps('authentication').authenticationType, 'EntraID'), steps('authentication').entraUserObjectIds, steps('authentication').hybridUserObjectIds)]",
      "desktopAccessAssignments": "[union(map(filter(split(replace(replace(steps('access').desktopUserObjectIds, '\\r\\n', ','), '\\n', ','), ','), (item) => not(empty(trim(item)))), (item) => parse(concat('{\"principalId\":\"', trim(item), '\",\"principalType\":\"User\"}'))), map(filter(split(replace(replace(steps('access').desktopGroupObjectIds, '\\r\\n', ','), '\\n', ','), ','), (item) => not(empty(trim(item)))), (item) => parse(concat('{\"principalId\":\"', trim(item), '\",\"principalType\":\"Group\"}'))))]",
      "remoteAppAccessAssignments": "[union(map(filter(split(replace(replace(steps('access').remoteAppUserObjectIds, '\\r\\n', ','), '\\n', ','), ','), (item) => not(empty(trim(item)))), (item) => parse(concat('{\"principalId\":\"', trim(item), '\",\"principalType\":\"User\"}'))), map(filter(split(replace(replace(steps('access').remoteAppGroupObjectIds, '\\r\\n', ','), '\\n', ','), ','), (item) => not(empty(trim(item)))), (item) => parse(concat('{\"principalId\":\"', trim(item), '\",\"principalType\":\"Group\"}'))))]",
      "remoteApps": "[if(or(equals(steps('instanceDetails').avdMode, 'PooledRemoteApp'), equals(steps('instanceDetails').avdMode, 'PooledDesktopAndRemoteApp')), parse(steps('access').remoteAppsJson), parse('[]'))]"
    }
  }
}
