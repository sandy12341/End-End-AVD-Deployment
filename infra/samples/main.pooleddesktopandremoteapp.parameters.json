{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "deploymentPrefix": { "value": "avd1" },
    "environment": { "value": "dev" },
    "sessionHostCount": { "value": 1 },
    "vmSize": { "value": "Standard_D2ads_v5" },
    "avdMode": { "value": "PooledDesktopAndRemoteApp" },
    "authenticationType": { "value": "EntraID" },
    "domainFqdn": { "value": "" },
    "domainJoinUsername": { "value": "" },
    "domainJoinPassword": { "value": "" },
    "domainJoinOuPath": { "value": "" },
    "hostPoolName": { "value": "hp-avd-desktopapps-dev" },
    "avdUserObjectIds": { "value": "" },
    "adminUsername": { "value": "avdadmin" },
    "deployFSLogix": { "value": true },
    "deployMonitoring": { "value": true },
    "remoteApps": {
      "value": [
        {
          "name": "notepad",
          "friendlyName": "Notepad",
          "filePath": "C:\\Windows\\System32\\notepad.exe"
        },
        {
          "name": "mspaint",
          "friendlyName": "Paint",
          "filePath": "C:\\Windows\\System32\\mspaint.exe"
        }
      ]
    },
    "existingVnetName": { "value": "existing-vnet-name" },
    "existingVnetResourceGroupName": { "value": "existing-vnet-resource-group" },
    "sessionHostSubnetName": { "value": "existing-sessionhost-subnet" },
    "privateEndpointSubnetName": { "value": "existing-privateendpoint-subnet" }
  }
}